Ecoli_sko_data <- combined_sko_data %>% filter(Organism == "Ecoli")
Sce_sko_data   <- combined_sko_data %>% filter(Organism == "Sce")
# --- Plotting E. coli ---
p_sko_Ecoli <- ggplot(Ecoli_sko_data, aes(x = Perturbed_TF, y = Product_Drop_Pct)) +
geom_boxplot(outlier.shape = NA, alpha = 0.4, fill = "lightblue",
color = "black", width = 0.6) +
geom_jitter(width = 0.15, size = 2.5, alpha = 0.8, color = "blue4") +
facet_wrap(~ Metabolite, scales = "free", ncol = 5) +
theme_bw(base_size = 14) +
labs(
title = "A",
x     = "",
y     = "Yield drop (%)"
) +
theme(
axis.text.x        = element_text(angle = 45, hjust = 1, face = "bold"),
panel.grid.major.x = element_blank(),
strip.background   = element_rect(fill = "grey90", color = "black"),
strip.text         = element_text(face = "bold", size = 12),
legend.position    = "none"
)
# --- Plotting Yeast ---
p_sko_Sce <- ggplot(Sce_sko_data, aes(x = Perturbed_TF, y = Product_Drop_Pct)) +
geom_boxplot(outlier.shape = NA, alpha = 0.4, fill = "lightblue",
color = "black", width = 0.6) +
geom_jitter(width = 0.15, size = 2.5, alpha = 0.8, color = "blue4") +
facet_wrap(~ Metabolite, scales = "free", ncol = 5) +
theme_bw(base_size = 14) +
labs(
title = "B",
x     = "Knocked-out Transcription Factor",
y     = "Yield drop (%)"
) +
theme(
axis.text.x        = element_text(angle = 45, hjust = 1, face = "bold"),
panel.grid.major.x = element_blank(),
strip.background   = element_rect(fill = "grey90", color = "black"),
strip.text         = element_text(face = "bold", size = 12),
legend.position    = "none"
)
