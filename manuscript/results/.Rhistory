library(tidyverse)
library(readxl)
library(patchwork)
library(viridis)
base_dir <- "~/Acadêmico/Posdoutorado/1_Main_project/tfReg/"
org_settings <- list(
Ecoli = list(
folder      = "Ecoli/Results",
metabolites = c("Acetate", "Ethanol", "Formate", "D-Lactate", "Succinate")
),
Sce = list(
folder      = "Yeast/Results",
metabolites = c("2-phenylethanol", "Ethanol", "Heme", "Phenylacetaldehyde", "Succinate")
)
)
combined_sko_data <- data.frame()
for (org in names(org_settings)) {
current_folder      <- file.path(base_dir, org_settings[[org]]$folder)
current_metabolites <- org_settings[[org]]$metabolites
for (met in current_metabolites) {
file_path <- file.path(current_folder, paste0(org, "_singleKO_", met, ".xlsx"))
if (file.exists(file_path)) {
df <- read_excel(file_path) %>%
mutate(
Organism   = org,
Metabolite = met
)
combined_sko_data <- bind_rows(combined_sko_data, df)
} else {
warning(paste("File not found and skipped:", file_path))
}
}
}
combined_sko_data <- combined_sko_data %>%
mutate(Drop_Percentage = pmax(Drop_Percentage, 0.1))
