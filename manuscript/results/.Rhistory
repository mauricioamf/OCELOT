# --- Combine ---
p_sko_Ecoli / p_sko_Sce
library(tidyverse)
library(readxl)
library(patchwork)
library(viridis)
base_dir <- "~/Acadêmico/Posdoutorado/1_Main_project/tfReg/"
org_settings <- list(
Ecoli = list(
folder = "Ecoli/Results",
metabolites = c("Acetate", "Ethanol", "Formate", "D-Lactate", "Succinate")
),
Sce = list(
folder = "Yeast/Results",
metabolites = c("2-phenylethanol", "Ethanol", "Heme", "Phenylacetaldehyde", "Succinate")
)
)
combined_loo_data <- data.frame()
for (org in names(org_settings)) {
current_folder <- file.path(base_dir, org_settings[[org]]$folder)
current_metabolites <- org_settings[[org]]$metabolites
for (met in current_metabolites) {
file_path <- file.path(current_folder, paste0(org, "_leaveOneOut_", met, ".xlsx"))
if (file.exists(file_path)) {
df <- read_excel(file_path)
df <- df %>%
mutate(
Organism = org,
Metabolite = met,
Drop_Percentage = if("Product_Drop_Pct" %in% names(.)) Product_Drop_Pct else Drop_Pct
)
combined_loo_data <- bind_rows(combined_loo_data, df)
} else {
warning(paste("File not found and skipped:", file_path))
}
}
}
# Clamp any value <= 0 to 0.1
combined_loo_data <- combined_loo_data %>%
mutate(Drop_Percentage = pmax(Drop_Percentage, 0.1))
Ecoli_loo_data <- combined_loo_data %>% filter(Organism == "Ecoli")
Sce_loo_data   <- combined_loo_data %>% filter(Organism == "Sce")
log_scale <- scale_y_log10(
limits = c(0.1, 100),
breaks = c(0.1, 1, 10, 100),
labels = c("0", "1", "10", "100")
)
# --- Plotting E. coli ---
p_loo_Ecoli <- ggplot(Ecoli_loo_data, aes(x = Restored_TF, y = Drop_Percentage)) +
geom_boxplot(outlier.shape = NA, alpha = 0.4, fill = "lightblue",
color = "black", width = 0.6) +
# Color aesthetic removed; fixed color used instead
geom_jitter(width = 0.15, size = 2.5, alpha = 0.8, color = "blue4") +
facet_wrap(~ Metabolite, scales = "fixed", ncol = 5) +
log_scale +
theme_bw(base_size = 14) +
labs(
title = "A",
x = "",
y = ""
) +
theme(
axis.text.x        = element_text(angle = 45, hjust = 1, face = "bold"),
panel.grid.major.x = element_blank(),
strip.background   = element_rect(fill = "grey90", color = "black"),
strip.text         = element_text(face = "bold", size = 12),
legend.position    = "none",
legend.title       = element_text(face = "bold")
)
# --- Plotting Yeast ---
p_loo_Sce <- ggplot(Sce_loo_data, aes(x = Restored_TF, y = Drop_Percentage)) +
geom_boxplot(outlier.shape = NA, alpha = 0.4, fill = "lightblue",
color = "black", width = 0.6) +
# Color aesthetic removed; fixed color used instead
geom_jitter(width = 0.15, size = 2.5, alpha = 0.8, color = "blue4") +
facet_wrap(~ Metabolite, scales = "fixed", ncol = 5) +
log_scale +
theme_bw(base_size = 14) +
labs(
title = "B",
x = "Restored Transcription Factor",
y = "Product Yield Drop (%)"
) +
theme(
axis.text.x        = element_text(angle = 45, hjust = 1, face = "bold"),
panel.grid.major.x = element_blank(),
strip.background   = element_rect(fill = "grey90", color = "black"),
strip.text         = element_text(face = "bold", size = 12),
legend.position    = "none",
legend.title       = element_text(face = "bold")
)
